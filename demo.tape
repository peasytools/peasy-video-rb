# peasy-video-rb — Video trim, resize, thumbnails (Ruby)
# Theme: Catppuccin Mocha
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "Catppuccin Mocha"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-video-rb — Video trim, resize, thumbnails for Ruby"
Enter
Type "# peasyvideo.com"
Enter
Sleep 500ms

# Run the demo
Type "ruby -I lib examples/demo.rb"
Enter
Sleep 5s
